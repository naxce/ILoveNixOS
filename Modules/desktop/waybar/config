{
  "layer": "top",
  "position": "top",
  "height": 36,
  "margin": "6 12 0 12",
  "spacing": 0,
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,

  "modules-left": [
    "custom/logo",
    "custom/separator",
    "custom/kwin-desktop",
    "custom/separator",
    "custom/window"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "custom/separator",
    "group/system",
    "custom/separator",
    "group/media",
    "custom/separator",
    "group/status",
    "custom/separator",
    "custom/power"
  ],

  "custom/logo": {
    "format": "  ",
    "tooltip": false,
    "on-click": "rofi -show drun"
  },

  "custom/kwin-desktop": {
    "exec": "python3 -c \"\nimport subprocess, json\nresult = subprocess.run(['qdbus', 'org.kde.KWin', '/VirtualDesktopManager', 'org.kde.KWin.VirtualDesktopManager.current'], capture_output=True, text=True)\ncurrent_id = result.stdout.strip()\nresult2 = subprocess.run(['qdbus', 'org.kde.KWin', '/VirtualDesktopManager', 'org.kde.KWin.VirtualDesktopManager.desktops'], capture_output=True, text=True)\ndesktops = [x for x in result2.stdout.strip().split() if x]\nkanji = ['一','二','三','四','五','六','七','八','九']\nout = ''\nfor i, d in enumerate(desktops):\n    if d == current_id:\n        out += f'<span color=\\\"#b4befe\\\"><b>{kanji[i] if i < len(kanji) else str(i+1)}</b></span> '\n    else:\n        out += f'<span color=\\\"#585b70\\\">{kanji[i] if i < len(kanji) else str(i+1)}</span> '\nprint(json.dumps({'text': out.strip(), 'tooltip': f'Desktop {desktops.index(current_id)+1 if current_id in desktops else 1}'}))\n\"",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-scroll-up": "qdbus org.kde.KWin /KWin org.kde.KWin.nextDesktop",
    "on-scroll-down": "qdbus org.kde.KWin /KWin org.kde.KWin.previousDesktop",
    "on-click": "qdbus org.kde.KWin /KWin org.kde.KWin.nextDesktop"
  },

  "custom/window": {
    "exec": "python3 -c \"\nimport subprocess\ntry:\n    r = subprocess.run(['qdbus', 'org.kde.KWin', '/KWin', 'org.kde.KWin.activeWindow'], capture_output=True, text=True)\n    wid = r.stdout.strip()\n    if wid and wid != '0':\n        r2 = subprocess.run(['qdbus', 'org.kde.KWin', f'/windows/window{wid}', 'org.kde.KWin.Window.caption'], capture_output=True, text=True)\n        title = r2.stdout.strip()[:45]\n        print(f'  {title}' if title else '')\n    else:\n        print('')\nexcept:\n    print('')\n\"",
    "interval": 2,
    "format": "{}",
    "tooltip": false
  },

  "clock": {
    "format": "  {:%H:%M}",
    "format-alt": "  {:%A, %d %B %Y}",
    "tooltip-format": "<span font='JetBrainsMono Nerd Font 10'><tt><small>{calendar}</small></tt></span>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months":   "<span color='#f5c2e7'><b>{}</b></span>",
        "days":     "<span color='#cdd6f4'>{}</span>",
        "weekdays": "<span color='#a6e3a1'><b>{}</b></span>",
        "today":    "<span color='#f38ba8'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  "group/system": {
    "orientation": "inherit",
    "modules": [ "cpu", "memory", "temperature", "disk" ]
  },

  "cpu": {
    "format": "󰻠 {usage}%",
    "interval": 2,
    "tooltip-format": "CPU: {usage}%\nLoad: {load}",
    "on-click": "alacritty -e btop"
  },

  "memory": {
    "format": "󰍛 {percentage}%",
    "interval": 5,
    "tooltip-format": "RAM: {used:.1f}G / {total:.1f}G\nSwap: {swapUsed:.1f}G / {swapTotal:.1f}G",
    "on-click": "alacritty -e btop"
  },

  "temperature": {
    "critical-threshold": 85,
    "format": "{icon} {temperatureC}°C",
    "format-critical": "󰸁 {temperatureC}°C",
    "format-icons": ["󱃃", "󰔏", "󱃂", "󰸁"],
    "interval": 5
  },

  "disk": {
    "format": "󰋊 {percentage_used}%",
    "path": "/",
    "interval": 30,
    "tooltip-format": "/ — {used} / {total}\nFree: {free}"
  },

  "group/media": {
    "orientation": "inherit",
    "modules": [ "pulseaudio", "backlight", "mpris" ]
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "󰂰 {volume}%",
    "format-muted": "󰝟 Mute",
    "format-icons": {
      "headphone": "󰋋",
      "headset": "󰋋",
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "scroll-step": 2,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip-format": "{desc}: {volume}%"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["󰃞", "󰃟", "󰃠"],
    "scroll-step": 5,
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip-format": "Brightness: {percent}%"
  },

  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{player_icon}  <i>{dynamic}</i>",
    "player-icons": {
      "default": "▶",
      "mpv": "󰝚",
      "spotify": "󰓇",
      "firefox": "󰈹",
      "chromium": ""
    },
    "status-icons": { "paused": "⏸" },
    "dynamic-len": 22,
    "dynamic-order": ["title", "artist"]
  },

  "group/status": {
    "orientation": "inherit",
    "modules": [ "network", "bluetooth", "battery" ]
  },

  "network": {
    "format": "󰤭 Offline",
    "format-wifi": "󰤨 {essid}",
    "format-ethernet": "󰈀 {ipaddr}",
    "format-disconnected": "󰤭 Offline",
    "tooltip-format-wifi": "SSID: {essid}\nSignal: {signalStrength}%\nIP: {ipaddr}",
    "tooltip-format": "IP: {ipaddr}\nGateway: {gwaddr}\n↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
    "on-click": "plasma-open-settings kcm_networkmanagement",
    "interval": 5
  },

  "bluetooth": {
    "format": " {status}",
    "format-connected": "󰂱 {device_alias}",
    "format-connected-battery": "󰂱 {device_alias} {device_battery_percentage}%",
    "format-off": "󰂲 Off",
    "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "on-click": "bluedevil-sendfile || systemsettings kcm_bluetooth"
  },

  "battery": {
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-full": "󰁹 Full",
    "format-icons": ["󰂎","󰁺","󰁻","󰁼","󰁽","󰁾","󰁿","󰂀","󰂁","󰂂","󰁹"],
    "tooltip-format": "{timeTo}\nPower: {power}W"
  },

  "custom/power": {
    "format": "⏻",
    "tooltip": false,
    "on-click": "qdbus org.kde.LogoutPrompt /LogoutPrompt org.kde.LogoutPrompt.promptAll"
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  }
}
