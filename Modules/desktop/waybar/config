{
  "layer": "top",
  "position": "top",
  "height": 36,
  "margin": "8 14 0 14",
  "spacing": 0,
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,

  "modules-left": [
    "custom/logo",
    "custom/kwin-desktop",
    "custom/separator",
    "custom/window"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "custom/separator",
    "group/system",
    "custom/separator",
    "group/media",
    "custom/separator",
    "group/status",
    "custom/separator",
    "custom/power"
  ],

  "custom/logo": {
    "format": " ",
    "tooltip": true,
    "tooltip-format": "NixOS — reproducible, declarative, reliable",
    "on-click": "rofi -show drun"
  },

  "custom/kwin-desktop": {
    "exec": "python3 -c \"\nimport subprocess, json\ntry:\n    r = subprocess.run(['qdbus','org.kde.KWin','/VirtualDesktopManager','org.kde.KWin.VirtualDesktopManager.current'],capture_output=True,text=True)\n    cur = r.stdout.strip()\n    r2 = subprocess.run(['qdbus','org.kde.KWin','/VirtualDesktopManager','org.kde.KWin.VirtualDesktopManager.desktops'],capture_output=True,text=True)\n    desks = [x for x in r2.stdout.strip().split() if x]\n    kanji=['一','二','三','四','五','六','七','八','九']\n    parts=[]\n    for i,d in enumerate(desks):\n        k=kanji[i] if i<len(kanji) else str(i+1)\n        if d==cur:\n            parts.append(f'<span color=\\\"#b4befe\\\"><b>{k}</b></span>')\n        else:\n            parts.append(f'<span color=\\\"#45475a\\\">{k}</span>')\n    print(json.dumps({'text':' '.join(parts),'tooltip':f'Desktop {desks.index(cur)+1 if cur in desks else 1} / {len(desks)}'}))\nexcept Exception as e:\n    print(json.dumps({'text':'·','tooltip':str(e)}))\n\"",
    "return-type": "json",
    "interval": 1,
    "format": "{}",
    "on-scroll-up": "qdbus org.kde.KWin /KWin org.kde.KWin.nextDesktop",
    "on-scroll-down": "qdbus org.kde.KWin /KWin org.kde.KWin.previousDesktop",
    "on-click": "qdbus org.kde.KWin /KWin org.kde.KWin.nextDesktop"
  },

  "custom/window": {
    "exec": "python3 -c \"\nimport subprocess\ntry:\n    r=subprocess.run(['qdbus','org.kde.KWin','/KWin','org.kde.KWin.activeWindow'],capture_output=True,text=True)\n    wid=r.stdout.strip()\n    if wid and wid!='0':\n        r2=subprocess.run(['qdbus','org.kde.KWin',f'/windows/window{wid}','org.kde.KWin.Window.caption'],capture_output=True,text=True)\n        title=r2.stdout.strip()[:50]\n        print(f'  {title}' if title else '')\n    else:\n        print('')\nexcept:\n    print('')\n\"",
    "interval": 2,
    "format": "{}",
    "tooltip": false
  },

  "clock": {
    "format": "  {:%H:%M}",
    "format-alt": "  {:%a, %d %b %Y}",
    "tooltip-format": "<span font='JetBrainsMono Nerd Font 10'><tt><small>{calendar}</small></tt></span>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months":   "<span color='#f5c2e7'><b>{}</b></span>",
        "days":     "<span color='#cdd6f4'>{}</span>",
        "weekdays": "<span color='#a6e3a1'><b>{}</b></span>",
        "today":    "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  "group/system": {
    "orientation": "inherit",
    "modules": [ "cpu", "memory", "temperature", "disk" ]
  },

  "cpu": {
    "format": "󰻠 {usage}%",
    "interval": 2,
    "tooltip": true,
    "tooltip-format": "CPU  {usage}%\nLoad {load}",
    "on-click": "alacritty -e btop"
  },

  "memory": {
    "format": "󰍛 {percentage}%",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "RAM   {used:.1f}G / {total:.1f}G\nSwap  {swapUsed:.1f}G / {swapTotal:.1f}G",
    "on-click": "alacritty -e btop"
  },

  "temperature": {
    "critical-threshold": 85,
    "format": "{icon} {temperatureC}°",
    "format-critical": "󰸁 {temperatureC}°",
    "format-icons": ["󱃃", "󰔏", "󱃂"],
    "interval": 4,
    "tooltip": true,
    "tooltip-format": "Temp  {temperatureC}°C"
  },

  "disk": {
    "format": "󰋊 {percentage_used}%",
    "path": "/",
    "interval": 30,
    "tooltip": true,
    "tooltip-format": "Disk  {used} / {total}\nFree  {free}"
  },

  "group/media": {
    "orientation": "inherit",
    "modules": [ "pulseaudio", "backlight", "mpris" ]
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "󰂰 {volume}%",
    "format-muted": "󰝟",
    "format-icons": {
      "headphone": "󰋋",
      "headset":   "󰋋",
      "default":   ["󰕿", "󰖀", "󰕾"]
    },
    "scroll-step": 2,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip": true,
    "tooltip-format": "{desc}\n{volume}%"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["󰃞", "󰃟", "󰃠"],
    "scroll-step": 5,
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip": true,
    "tooltip-format": "Brightness  {percent}%"
  },

  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{player_icon}  {dynamic}",
    "player-icons": {
      "default":  "▶",
      "mpv":      "󰝚",
      "spotify":  "󰓇",
      "firefox":  "󰈹",
      "chromium": ""
    },
    "status-icons": { "paused": "⏸" },
    "dynamic-len": 20,
    "dynamic-order": ["title", "artist"],
    "tooltip": true,
    "tooltip-format": "{player}\n{title}\n{artist}"
  },

  "group/status": {
    "orientation": "inherit",
    "modules": [ "network", "bluetooth", "battery" ]
  },

  "network": {
    "format": "󰤭",
    "format-wifi": "󰤨 {essid}",
    "format-ethernet": "󰈀 {ipaddr}",
    "format-disconnected": "󰤭 —",
    "tooltip": true,
    "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
    "tooltip-format": "{ifname}\n{ipaddr}  {gwaddr}\n↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
    "on-click": "plasma-open-settings kcm_networkmanagement",
    "interval": 5
  },

  "bluetooth": {
    "format": " {status}",
    "format-connected": "󰂱 {device_alias}",
    "format-connected-battery": "󰂱 {device_alias} {device_battery_percentage}%",
    "format-off": "󰂲",
    "tooltip": true,
    "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "  {device_alias}",
    "tooltip-format-enumerate-connected-battery": "  {device_alias}  {device_battery_percentage}%",
    "on-click": "systemsettings kcm_bluetooth"
  },

  "battery": {
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-full": "󰁹",
    "format-icons": ["󰂎","󰁺","󰁻","󰁼","󰁽","󰁾","󰁿","󰂀","󰂁","󰂂","󰁹"],
    "tooltip": true,
    "tooltip-format": "{timeTo}\n{power}W"
  },

  "custom/power": {
    "format": "⏻",
    "tooltip": true,
    "tooltip-format": "Session menu",
    "on-click": "qdbus org.kde.LogoutPrompt /LogoutPrompt org.kde.LogoutPrompt.promptAll"
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  }
}
