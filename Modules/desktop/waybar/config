{
  "layer": "top",
  "position": "top",
  "height": 40,
  "spacing": 0,
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "margin-top": 6,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": [
    "custom/logo",
    "hyprland/workspaces",
    "custom/separator",
    "hyprland/window"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "custom/separator",
    "group/system",
    "custom/separator",
    "group/media",
    "custom/separator",
    "group/status",
    "custom/separator",
    "custom/power"
  ],

  // ─── Logo / Launcher ──────────────────────────────────────────
  "custom/logo": {
    "format": "  ",
    "tooltip": false,
    "on-click": "rofi -show drun -theme ~/.config/rofi/launcher.rasi"
  },

  // ─── Workspaces ───────────────────────────────────────────────
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1":  "一",
      "2":  "二",
      "3":  "三",
      "4":  "四",
      "5":  "五",
      "6":  "六",
      "7":  "七",
      "8":  "八",
      "9":  "九",
      "urgent": "",
      "active": "",
      "default": "·"
    },
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    },
    "sort-by-number": true
  },

  // ─── Active Window ────────────────────────────────────────────
  "hyprland/window": {
    "format": "  {title}",
    "max-length": 40,
    "rewrite": {
      "(.*) — Mozilla Firefox": " Firefox · $1",
      "(.*) - Visual Studio Code": "󰨞 Code · $1",
      "Alacritty": " Terminal",
      "dolphin": " Files",
      "(.*)": "$1"
    },
    "separate-outputs": true
  },

  // ─── Clock ────────────────────────────────────────────────────
  "clock": {
    "format": "  {:%H:%M}",
    "format-alt": "  {:%A, %d %B %Y}",
    "tooltip-format": "<span font='JetBrainsMono Nerd Font 10'><tt><small>{calendar}</small></tt></span>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months":     "<span color='#f5c2e7'><b>{}</b></span>",
        "days":       "<span color='#cdd6f4'>{}</span>",
        "weeks":      "<span color='#89dceb'><b>W{}</b></span>",
        "weekdays":   "<span color='#a6e3a1'><b>{}</b></span>",
        "today":      "<span color='#f38ba8'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  // ─── System Group ─────────────────────────────────────────────
  "group/system": {
    "orientation": "inherit",
    "modules": [
      "cpu",
      "memory",
      "temperature",
      "disk"
    ]
  },

  "cpu": {
    "format": "󰻠 {usage}%",
    "interval": 2,
    "tooltip": true,
    "tooltip-format": "CPU: {usage}%\nLoad: {load}",
    "on-click": "alacritty -e btop"
  },

  "memory": {
    "format": "󰍛 {percentage}%",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "RAM: {used:.1f}G / {total:.1f}G\nSwap: {swapUsed:.1f}G / {swapTotal:.1f}G",
    "on-click": "alacritty -e btop"
  },

  "temperature": {
    "thermal-zone": 0,
    "hwmon-path-abs": "/sys/class/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 85,
    "format": "{icon} {temperatureC}°C",
    "format-critical": "󰸁 {temperatureC}°C",
    "format-icons": ["󱃃", "󰔏", "󱃂", "󰸁"],
    "interval": 5,
    "tooltip": true
  },

  "disk": {
    "format": "󰋊 {percentage_used}%",
    "path": "/",
    "interval": 30,
    "tooltip": true,
    "tooltip-format": "/ — {used} / {total}\nFree: {free}"
  },

  // ─── Media Group ──────────────────────────────────────────────
  "group/media": {
    "orientation": "inherit",
    "modules": [
      "pulseaudio",
      "backlight",
      "mpris"
    ]
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "󰂰 {volume}%",
    "format-muted": "󰝟",
    "format-icons": {
      "headphone": "󰋋",
      "hands-free": "󱡏",
      "headset": "󰋋",
      "phone": "󰏲",
      "portable": "󰏲",
      "car": "󰄋",
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "scroll-step": 2,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "tooltip": true,
    "tooltip-format": "{desc}: {volume}%"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["󰃞", "󰃟", "󰃠"],
    "scroll-step": 5,
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip": true,
    "tooltip-format": "Brightness: {percent}%"
  },

  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{player_icon}  <i>{dynamic}</i>",
    "player-icons": {
      "default": "▶",
      "mpv": "󰝚",
      "spotify": "󰓇",
      "firefox": "󰈹",
      "chromium": ""
    },
    "status-icons": {
      "paused": "⏸"
    },
    "dynamic-len": 25,
    "dynamic-order": ["title", "artist"],
    "ignored-players": ["firefox"]
  },

  // ─── Status Group ─────────────────────────────────────────────
  "group/status": {
    "orientation": "inherit",
    "modules": [
      "network",
      "bluetooth",
      "battery"
    ]
  },

  "network": {
    "format": "󰤭 Offline",
    "format-wifi": "󰤨 {essid}",
    "format-ethernet": "󰈀 {ipaddr}",
    "format-disconnected": "󰤭 Offline",
    "tooltip": true,
    "tooltip-format": "Interface: {ifname}\nIP: {ipaddr}/{cidr}\nGateway: {gwaddr}\nSpeed: ↑{bandwidthUpBytes} ↓{bandwidthDownBytes}",
    "tooltip-format-wifi": "SSID: {essid}\nSignal: {signalStrength}%\nFreq: {frequency}MHz\nIP: {ipaddr}",
    "on-click": "nm-connection-editor",
    "interval": 5
  },

  "bluetooth": {
    "format": " {status}",
    "format-connected": "󰂱 {device_alias}",
    "format-connected-battery": "󰂱 {device_alias} {device_battery_percentage}%",
    "format-off": "󰂲",
    "tooltip": true,
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "blueberry"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-full": "󰁹 Full",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "tooltip": true,
    "tooltip-format": "{timeTo}\nPower: {power}W\nCycles: {cycles}"
  },

  // ─── Power ────────────────────────────────────────────────────
  "custom/power": {
    "format": "⏻",
    "tooltip": false,
    "on-click": "wlogout --protocol layer-shell -b 5 -T 400 -B 400"
  },

  // ─── Separator ────────────────────────────────────────────────
  "custom/separator": {
    "format": "|",
    "tooltip": false
  }
}
